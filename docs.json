{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Outcome",
  "theme": "luma",
  "colors": {
    "primary": "#6f2ee4",
    "light": "#ddccfe",
    "dark": "#6f2ee4"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Open App",
      "href": "https://outcome.xyz"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Platform",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "platform/overview",
              "platform/how-it-works"
            ]
          },
          {
            "group": "Trading",
            "pages": [
              "platform/trading/placing-orders",
              "platform/trading/order-types",
              "platform/trading/positions",
              "platform/trading/converting"
            ]
          },
          {
            "group": "Funds",
            "pages": [
              "platform/funds/depositing",
              "platform/funds/withdrawing"
            ]
          }
        ]
      },
      {
        "tab": "SDK",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "sdk/introduction",
              "sdk/installation",
              "sdk/quickstart"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "sdk/concepts/markets",
              "sdk/concepts/authentication",
              "sdk/concepts/coin-naming"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "sdk/guides/fetch-markets",
              "sdk/guides/trading",
              "sdk/guides/conversions",
              "sdk/guides/real-time-data",
              "sdk/guides/wallet-funding"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "sdk/reference/events-adapter",
              "sdk/reference/market-data-adapter",
              "sdk/reference/trading-adapter",
              "sdk/reference/account-adapter",
              "sdk/reference/wallet-adapter",
              "sdk/reference/auth-adapter",
              "sdk/reference/utilities",
              "sdk/reference/types"
            ]
          }
        ]
      }
    ]
  },
  "favicon": "/images/favicon-32x32.png",
  "logo": {
    "light": "/images/lockup-light-gray.svg",
    "dark": "/images/lockup-dark-gray.svg"
  },
  "appearance": {
    "default": "light",
    "strict": false
  },
  "fonts": {
    "family": "Geist"
  },
  "banner": {
    "content": "Outcome V2 is live here: https://outcome.xyz"
  },
  "thumbnails": {
    "appearance": "light"
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": [
      "copy",
      "chatgpt",
      "claude",
      "cursor",
      "vscode",
      "mcp",
      "add-mcp"
    ]
  }
}
