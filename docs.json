{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Outcome",
  "theme": "mint",
  "colors": {
    "primary": "#171717",
    "light": "#f5f5f5",
    "dark": "#171717"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Open App",
      "href": "https://outcome.xyz"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "icon": "rocket",
            "pages": [
              "index",
              "getting-started"
            ]
          },
          {
            "group": "Concepts",
            "icon": "lightbulb",
            "pages": [
              "concepts/prediction-markets",
              "concepts/markets",
              "concepts/hyperliquid"
            ]
          },
          {
            "group": "Trading",
            "icon": "arrow-left-right",
            "pages": [
              "trading/guide"
            ]
          },
          {
            "group": "Reference",
            "icon": "receipt",
            "pages": [
              "reference/fees",
              "reference/risks"
            ]
          }
        ]
      },
      {
        "tab": "SDK Reference",
        "groups": [
          {
            "group": "Get Started",
            "icon": "rocket",
            "pages": [
              "sdk/introduction",
              "sdk/installation",
              "sdk/quickstart"
            ]
          },
          {
            "group": "Concepts",
            "icon": "book-open",
            "pages": [
              "sdk/concepts/markets",
              "sdk/concepts/authentication",
              "sdk/concepts/coin-naming"
            ]
          },
          {
            "group": "Guides",
            "icon": "list-checks",
            "pages": [
              "sdk/guides/fetch-markets",
              "sdk/guides/trading",
              "sdk/guides/conversions",
              "sdk/guides/real-time-data",
              "sdk/guides/wallet-funding"
            ]
          },
          {
            "group": "Adapters",
            "icon": "package",
            "pages": [
              "sdk/reference/events-adapter",
              "sdk/reference/market-data-adapter",
              "sdk/reference/trading-adapter",
              "sdk/reference/account-adapter",
              "sdk/reference/wallet-adapter",
              "sdk/reference/auth-adapter"
            ]
          },
          {
            "group": "Utilities",
            "icon": "wrench",
            "pages": [
              "sdk/reference/utilities",
              "sdk/reference/types"
            ]
          }
        ]
      }
    ]
  },
  "favicon": "/images/favicon-32x32.png",
  "logo": {
    "light": "/images/lockup-light-gray.svg",
    "dark": "/images/lockup-dark-gray.svg"
  },
  "appearance": {
    "default": "light",
    "strict": false
  },
  "fonts": {
    "family": "Geist"
  },
  "banner": {
    "content": "Outcome V2 is live here: https://outcome.xyz"
  },
  "thumbnails": {
    "appearance": "light"
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": [
      "copy",
      "chatgpt",
      "claude",
      "cursor",
      "vscode",
      "mcp",
      "add-mcp"
    ]
  }
}
