{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Outcome",
  "theme": "luma",
  "colors": {
    "primary": "#2DD4BF",
    "light": "#F0FDFA",
    "dark": "#0D9488"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/Infinite-Code-Org/outcome-app-monorepo"
    },
    "links": [
      {
        "href": "https://outcome.xyz",
        "label": "App"
      }
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Platform",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "platform/overview",
              "platform/how-it-works"
            ]
          },
          {
            "group": "Trading",
            "pages": [
              "platform/trading/placing-orders",
              "platform/trading/order-types",
              "platform/trading/positions"
            ]
          },
          {
            "group": "Funds",
            "pages": [
              "platform/funds/depositing",
              "platform/funds/withdrawing"
            ]
          }
        ]
      },
      {
        "tab": "SDK",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "sdk/introduction",
              "sdk/installation",
              "sdk/quickstart"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "sdk/concepts/markets",
              "sdk/concepts/authentication",
              "sdk/concepts/coin-naming"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "sdk/guides/fetch-markets",
              "sdk/guides/trading",
              "sdk/guides/real-time-data",
              "sdk/guides/wallet-funding"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "sdk/reference/events-adapter",
              "sdk/reference/market-data-adapter",
              "sdk/reference/trading-adapter",
              "sdk/reference/account-adapter",
              "sdk/reference/wallet-adapter",
              "sdk/reference/auth-adapter",
              "sdk/reference/utilities",
              "sdk/reference/types"
            ]
          }
        ]
      }
    ]
  },
  "favicon": "/images/favicon-32x32.png",
  "logo": "/images/lockup-dark-gray.svg",
  "background": {
    "image": "/images/lockup-dark-gray.svg",
    "decoration": "gradient"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "fonts": {
    "family": "Inter"
  },
  "banner": {
    "content": "Outcome V2 is live here: https://outcome.xyz"
  },
  "thumbnails": {
    "appearance": "dark"
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  }
}
