{
  "projectType": "sdk-library",
  "projectName": "Outcome",
  "projectDescription": "A TypeScript SDK for building on Hyperliquid HIP-4 binary prediction markets - fetch events, stream real-time orderbook data, place orders, and manage funds with zero dependencies.",
  "theme": "luma",
  "primaryColor": "#2DD4BF",
  "lightColor": "#F0FDFA",
