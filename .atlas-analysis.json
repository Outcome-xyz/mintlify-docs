  "keyFeatures": [
    "Zero-dependency TypeScript SDK for HIP-4 prediction markets",
    "Typed market discovery with defaultBinary, labelledBinary, multiOutcome, and priceBucket market types",
    "Real-time WebSocket subscriptions for order books, prices, and trades",
    "EIP-712 signing support for both L1 agent signing and user-signed operations",
    "USDH fund management: deposit, withdraw, transfer between perp and spot",
    "Tick-aligned pricing with min-notional validation before order submission",
    "Price feed streaming with historical candle merging for live charts",
    "Builder fee and referral address support on order placement",
    "Mainnet and testnet support with configurable endpoints"
  ],
  "publicApiSurface": [
    "createHIP4Adapter(config)",
    "adapter.events.fetchEvents(params?)",
    "adapter.events.fetchEvent(eventId)",
    "adapter.events.fetchCategories()",
    "adapter.events.fetchMarkets(params?)",
    "adapter.marketData.fetchOrderBook(marketId, sideIndex?)",
    "adapter.marketData.fetchPrice(marketId)",
    "adapter.marketData.fetchTrades(marketId, limit?)",
    "adapter.marketData.fetchCandles(marketId, interval?, start?, end?)",
    "adapter.marketData.subscribeOrderBook(marketId, cb)",
    "adapter.marketData.subscribePrice(marketId, cb)",
    "adapter.marketData.subscribeTrades(marketId, cb)",
    "adapter.account.fetchPositions(address)",
    "adapter.account.fetchActivity(address)",
    "adapter.account.fetchBalance(address)",
    "adapter.account.fetchOpenOrders(address)",
    "adapter.account.subscribePositions(address, cb)",
    "adapter.trading.placeOrder(params)",
    "adapter.trading.cancelOrder(params)",
    "adapter.auth.initAuth(walletAddress, signer)",
    "adapter.auth.getAuthStatus()",
    "adapter.auth.clearAuth()",
    "adapter.wallet.setSigner(signer)",
    "adapter.wallet.buyUsdh(amount)",
    "adapter.wallet.sellUsdh(amount)",
    "adapter.wallet.transferToSpot(amount)",
    "adapter.wallet.transferToPerps(amount)",
    "adapter.wallet.withdraw(params)",
    "adapter.wallet.usdSend(params)",
    "getAgentApprovalTypedData(agentAddress, name, nonce, testnet)",
    "submitAgentApproval(sig, agentAddress, name, nonce, testnet)",
    "createPriceFeed(marketData, marketId, onSnapshot, options?)",
    "createPerpPriceFeed(marketData, coin, onSnapshot, options?)",
    "formatPrice(price)",
    "computeTickSize(price)",
    "roundToTick(price)",
    "getMinShares(markPx)",
    "MIN_NOTIONAL",
    "parseDescription(description)",
    "classifyOutcome(outcome, questions)",
    "classifyAllOutcomes(meta)",
    "sideCoin(outcomeId, sideIndex)",
    "sideAssetId(outcomeId, sideIndex)",
    "parseSideCoin(coin)",
    "outcomeCoin(outcomeId)",
    "computeEstimatedCost(tokenAmount, orderType, limitPriceCents, marketPriceCents?)",
    "computeTradeCost(params)",
    "computePotentialReturn(tokenAmount)"
